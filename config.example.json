{
  "pcap_file": true,
  "regex_replacements": [
    {
      "stream": "stdout",
      "pattern": "password=\\w+",
      "replace": "password=***REDACTED***"
    },
    {
      "stream": "stderr",
      "pattern": "ERROR",
      "replace": "WARNING"
    },
    {
      "stream": "all",
      "pattern": "\\b\\d{3}-\\d{2}-\\d{4}\\b",
      "replace": "XXX-XX-XXXX"
    }
  ]
}
